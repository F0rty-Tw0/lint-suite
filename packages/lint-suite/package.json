{
  "name": "lint-suite",
  "version": "1.3.11",
  "description": "Reusable ESLint configurations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F0rty-Tw0/lint-suite.git",
    "directory": "packages/lint-suite"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "lint",
    "typescript",
    "angular",
    "storybook",
    "json",
    "rxjs",
    "vitest",
    "playwright"
  ],
  "license": "MIT",
  "author": "Artiom Tofan artiomtofancv@gmail.com",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@nx/eslint-plugin": "22.7.3",
    "@smarttools/eslint-plugin-rxjs": "1.0.22",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/utils": "8.59.4",
    "@vitest/eslint-plugin": "1.6.18",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-storybook": "10.4.1",
    "globals": "17.6.0",
    "typescript-eslint": "8.59.4"
  },
  "scripts": {
    "build": "nx build lint-suite"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "files": [
    "./**",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  }
}
