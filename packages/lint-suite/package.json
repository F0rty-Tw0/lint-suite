{
  "name": "lint-suite",
  "version": "1.3.8",
  "description": "Reusable ESLint configurations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F0rty-Tw0/lint-suite.git",
    "directory": "packages/lint-suite"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "lint",
    "typescript",
    "jest",
    "angular",
    "storybook",
    "json",
    "rxjs",
    "vitest",
    "playwright"
  ],
  "license": "MIT",
  "author": "Artiom Tofan artiomtofancv@gmail.com",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint-plugin": "22.7.1",
    "@smarttools/eslint-plugin-rxjs": "1.0.22",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/utils": "8.59.2",
    "@vitest/eslint-plugin": "1.6.16",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-playwright": "2.10.2",
    "eslint-plugin-storybook": "10.3.6",
    "globals": "17.6.0",
    "typescript-eslint": "8.59.2"
  },
  "scripts": {
    "build": "nx build lint-suite"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "files": [
    "./**",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  }
}
