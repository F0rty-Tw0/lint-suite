{
  "name": "lint-suite",
  "version": "1.4.0",
  "description": "Reusable ESLint, Stylelint, and Prettier configurations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F0rty-Tw0/lint-suite.git",
    "directory": "packages/lint-suite"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "lint",
    "typescript",
    "angular",
    "storybook",
    "json",
    "rxjs",
    "vitest",
    "playwright",
    "stylelint",
    "prettier"
  ],
  "license": "MIT",
  "author": "Artiom Tofan artiomtofancv@gmail.com",
  "type": "module",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@nx/eslint-plugin": "23.1.0",
    "@smarttools/eslint-plugin-rxjs": "1.0.22",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/utils": "8.64.0",
    "@vitest/eslint-plugin": "1.6.23",
    "angular-eslint": "^22.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-boundaries": "7.0.2",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-playwright": "2.10.5",
    "eslint-plugin-storybook": "10.5.2",
    "globals": "17.7.0",
    "stylelint": "17.14.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-scss": "7.2.0",
    "stylelint-selector-bem-pattern": "5.0.0",
    "typescript-eslint": "8.64.0"
  },
  "peerDependencies": {
    "prettier": "^3.8.3"
  },
  "scripts": {
    "build": "nx build lint-suite"
  },
  "exports": {
    "./package.json": "./package.json",
    "./eslint": {
      "types": "./eslint.d.ts",
      "import": "./eslint.js",
      "require": "./eslint.cjs"
    },
    "./stylelint": {
      "types": "./stylelint.d.ts",
      "import": "./stylelint.js",
      "require": "./stylelint.cjs"
    },
    "./prettier": {
      "types": "./prettier.d.ts",
      "import": "./prettier.js",
      "require": "./prettier.cjs"
    }
  },
  "files": [
    "./**",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  }
}
