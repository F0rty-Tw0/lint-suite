{
  "git": {
    "commit": true,
    "commitMessage": "chore(release): 🔖 v${version}",
    "tag": true,
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "push": true,
    "requireBranch": "main",
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": false,
    "skipChecks": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "hooks": {
    "after:bump": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('packages/lint-suite/package.json'));p.version='${version}';fs.writeFileSync('packages/lint-suite/package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "before:release": "pnpm exec nx run lint-suite:build"
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "packages/lint-suite/CHANGELOG.md",
      "head": "HEAD",
      "addUnreleased": true,
      "addVersionUrl": true,
      "versionUrlFormats": {
        "repositoryUrl": "https://github.com/F0rty-Tw0/lint-suite",
        "unreleasedUrl": "{repositoryUrl}/compare/{tagName}...{head}",
        "versionUrl": "{repositoryUrl}/compare/{previousTag}...{tagName}",
        "firstVersionUrl": "{repositoryUrl}/releases/tag/{tagName}"
      }
    }
  }
}
